; Engine configuration file.
; LUMENFALL — Arcaea-inspired lane rhythm game (Godot 4.4)

config_version=5

[application]

config/name="LUMENFALL"
config/description="Addictive dual-lane rhythm action inspired by Arcaea. Tap, hold, and trace lumen arcs."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://assets/textures/icon.svg"

[autoload]

GameState="*res://scripts/autoload/GameState.gd"
ChartLibrary="*res://scripts/autoload/ChartLibrary.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/handheld/orientation=1

