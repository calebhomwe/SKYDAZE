{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev-fp8.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    },
    "_meta": {"title": "FLUX UNet"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp8_e4m3fn.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    },
    "_meta": {"title": "FLUX dual CLIP"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ae.safetensors"},
    "_meta": {"title": "FLUX VAE"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "{{POSITIVE_PROMPT}}", "clip": ["2", 0]},
    "_meta": {"title": "Positive"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "lowres, cartoon, anime, neon, plastic, mannequin, watermark",
      "clip": ["2", 0]
    },
    "_meta": {"title": "Negative"}
  },
  "6": {
    "class_type": "FluxGuidance",
    "inputs": {"conditioning": ["4", 0], "guidance": 3.5},
    "_meta": {"title": "Flux guidance"}
  },
  "7": {
    "class_type": "LoadImage",
    "inputs": {"image": "{{CONTROLNET_IMAGE}}"},
    "_meta": {"title": "Load FTC silhouette SVG (uploaded)"}
  },
  "8": {
    "class_type": "Canny",
    "inputs": {"image": ["7", 0], "low_threshold": 0.1, "high_threshold": 0.3},
    "_meta": {"title": "Canny edges"}
  },
  "9": {
    "class_type": "ControlNetLoader",
    "inputs": {"control_net_name": "flux-canny-controlnet-v3.safetensors"},
    "_meta": {"title": "ControlNet (Flux Canny v3)"}
  },
  "10": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["5", 0],
      "control_net": ["9", 0],
      "image": ["8", 0],
      "strength": 0.65,
      "start_percent": 0.0,
      "end_percent": 0.55,
      "vae": ["3", 0]
    },
    "_meta": {"title": "Apply ControlNet (loose)"}
  },
  "11": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "{{WIDTH}}", "height": "{{HEIGHT}}", "batch_size": 1},
    "_meta": {"title": "Empty latent"}
  },
  "12": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "beta",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["10", 0],
      "negative": ["10", 1],
      "latent_image": ["11", 0]
    },
    "_meta": {"title": "KSampler (Flux + CN)"}
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["12", 0], "vae": ["3", 0]},
    "_meta": {"title": "Decode"}
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": {"images": ["13", 0], "filename_prefix": "ftc_cn"},
    "_meta": {"title": "Save"}
  }
}
