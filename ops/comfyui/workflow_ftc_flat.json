{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev-fp8.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    },
    "_meta": {"title": "FLUX UNet (FP8)"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp8_e4m3fn.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    },
    "_meta": {"title": "FLUX dual CLIP"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ae.safetensors"},
    "_meta": {"title": "FLUX VAE"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{POSITIVE_PROMPT}}",
      "clip": ["2", 0]
    },
    "_meta": {"title": "Positive (FTC brief)"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "lowres, jpeg artifacts, cartoon, anime, neon, blurry, plastic, mannequin face, branding logo plate, watermark, cluttered background",
      "clip": ["2", 0]
    },
    "_meta": {"title": "Negative"}
  },
  "6": {
    "class_type": "FluxGuidance",
    "inputs": {"conditioning": ["4", 0], "guidance": 3.5},
    "_meta": {"title": "Flux guidance 3.5"}
  },
  "7": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "{{WIDTH}}", "height": "{{HEIGHT}}", "batch_size": 1},
    "_meta": {"title": "Empty latent 4:5"}
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "beta",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["5", 0],
      "latent_image": ["7", 0]
    },
    "_meta": {"title": "KSampler (Flux)"}
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["8", 0], "vae": ["3", 0]},
    "_meta": {"title": "Decode"}
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {"images": ["9", 0], "filename_prefix": "ftc"},
    "_meta": {"title": "Save"}
  }
}
