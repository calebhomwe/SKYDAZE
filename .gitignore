# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
.eggs/
*.egg-info/
build/
dist/

# --- IDE ---
.idea/
.vscode/
.cursor/
*.swp
*.swo
.DS_Store

# --- FTC artifacts (regenerable; mostly excluded) ---
# Default: exclude everything in artifacts
artifacts/*
# But re-include lightweight viewable outputs (gallery + SVG graphics + worlds + markdown logs)
!artifacts/graphics/
!artifacts/graphics-bold/
!artifacts/game/
!artifacts/gallery.html
!artifacts/work_log/
# Within those re-included directories, exclude heavy/sensitive subpaths
artifacts/game/genesis/renders/
artifacts/game/genesis/audio/
artifacts/game/genesis/characters/*.png
artifacts/game/genesis/items/*.png
artifacts/graphics/*.png
artifacts/graphics-bold/*.png

# --- Mobile / Secrets ---
mobile/ftc-ios/FTC/Resources/Secrets.plist

# --- Logs & caches ---
*.log
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Secrets ---
*.key
*.pem
secrets/
